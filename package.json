{
  "name": "todoversus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:apply:local": "wrangler d1 execute todoversus-db --local --file=./prisma/schema.sql",
    "postinstall": "prisma generate",
    "build:cf": "mkdir -p node_modules/next/dist/compiled/@vercel/og && cp -r node_modules/@vercel/og/dist/* node_modules/next/dist/compiled/@vercel/og/ && next build && npx @opennextjs/cloudflare@latest build && node patch-worker.mjs",
    "deploy:cf": "npx wrangler deploy",
    "deploy": "npm run deploy:cf",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.13",
    "@vercel/og": "^0.11.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "satori": "^0.26.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^11.8.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.77.0"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-darwin-arm64": "^0.1.97",
    "@napi-rs/canvas-linux-x64-gnu": "^0.1.97"
  }
}
