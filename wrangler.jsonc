{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "todoversus",
	"compatibility_date": "2025-01-01",
	"main": ".open-next/worker.js",
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "todoversus-db",
			"database_id": "d3fc2672-d0d7-4d90-bd9b-296a48683844"
		}
	],
	"compatibility_flags": [
		"nodejs_compat"
	],
	"minify": true
}