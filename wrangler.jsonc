{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "todoversus",
	"account_id": "3195c88918d75f67924d7112641b8be3",
	"compatibility_date": "2025-01-01",
	"main": ".open-next/worker.js",
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "todoversus-db",
			"database_id": "73883563-661b-4114-b127-75ed6fe5fa63"
		}
	],
	"compatibility_flags": [
		"nodejs_compat"
	],
	"minify": true
}