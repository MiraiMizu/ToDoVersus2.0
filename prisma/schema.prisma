generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "jsonProtocol"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String            @id @default(cuid())
  username          String            @unique
  email             String            @unique
  passwordHash      String
  avatarUrl         String?
  motto             String?           @default("Ready for battle!")
  rank              String            @default("Bronze")
  streak            Int               @default(0)
  lastLogDate       DateTime?
  allTimeScore      Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  activityLogs      ActivityLog[]
  dailyScores       DailyScore[]
  wonMatches        Match[]           @relation("Winner")
  opponentMatches   Match[]           @relation("Opponent")
  challengedMatches Match[]           @relation("Challenger")
  suspiciousLogs    SuspiciousLog[]
  todos             Todo[]
  achievements      UserAchievement[]
  matchTasks        MatchTask[]
  reactions         Reaction[]
}

model Category {
  id              String          @id @default(cuid())
  name            String          @unique
  weight          Int
  description     String?
  color           String          @default("#6366f1")
  activityLogs    ActivityLog[]
  matchCategories MatchCategory[]
  matchTasks      MatchTask[]
  todos           Todo[]
}

model Match {
  id            String          @id @default(cuid())
  challengerId  String
  opponentId    String
  status        String          @default("PENDING")
  startDate     DateTime?
  endDate       DateTime?
  durationHours Int             @default(24)
  winnerId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  activityLogs  ActivityLog[]
  bet           Bet?
  dailyScores   DailyScore[]
  winner        User?           @relation("Winner", fields: [winnerId], references: [id])
  opponent      User            @relation("Opponent", fields: [opponentId], references: [id])
  challenger    User            @relation("Challenger", fields: [challengerId], references: [id])
  categories    MatchCategory[]
  matchTasks    MatchTask[]
}

model Bet {
  id                 String   @id @default(cuid())
  matchId            String   @unique
  content            String
  challengerApproved Boolean  @default(false)
  opponentApproved   Boolean  @default(false)
  createdAt          DateTime @default(now())
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchCategory {
  id         String   @id @default(cuid())
  matchId    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, categoryId])
}

model MatchTask {
  id           String        @id @default(cuid())
  matchId      String
  userId       String
  content      String
  categoryId   String
  createdAt    DateTime      @default(now())
  activityLogs ActivityLog[]
  category     Category      @relation(fields: [categoryId], references: [id])
  match        Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
}

model Todo {
  id          String    @id @default(cuid())
  userId      String
  content     String
  isCompleted Boolean   @default(false)
  date        String
  categoryId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id              String     @id @default(cuid())
  userId          String
  matchId         String?
  matchTaskId     String?
  categoryId      String
  name            String
  durationMinutes Int
  score           Int
  loggedAt        DateTime   @default(now())
  date            String
  category        Category   @relation(fields: [categoryId], references: [id])
  matchTask       MatchTask? @relation(fields: [matchTaskId], references: [id])
  match           Match?     @relation(fields: [matchId], references: [id])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions       Reaction[]
}

model DailyScore {
  id         String   @id @default(cuid())
  userId     String
  matchId    String?
  date       String
  totalScore Int      @default(0)
  updatedAt  DateTime @updatedAt
  match      Match?   @relation(fields: [matchId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, matchId, date])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String
  icon             String            @default("🏆")
  rarity           String            @default("Common")
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  awardedAt     DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
}

model SuspiciousLog {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Reaction {
  id            String      @id @default(cuid())
  activityLogId String
  userId        String
  emoji         String
  createdAt     DateTime    @default(now())
  activityLog   ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityLogId, userId, emoji])
}
